<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Airbnb-clone</title>
  </head>
  <body>
    <h3 style="text-align: center">Add New Listing</h3>
    <div
      style="
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        margin: 1rem;
      "
    >
      <form
        action="/listings"
        method="POST"
        style="display: flex; flex-direction: column; gap: 1rem; width: 50%"
      >
        <input
          type="text"
          name="title"
          placeholder="Title"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <textarea
          name="description"
          placeholder="Description"
          style="
            padding: 0.5rem;
            width: 100%;
            height: 100px;
            border: 1px solid #ccc;
            border-radius: 1rem;
          "
        ></textarea>
        <br />
        <input
          type="text"
          name="image.filename"
          placeholder="Image Filename"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <input
          type="text"
          name="image.url"
          placeholder="Image URL"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <input
          type="number"
          name="price"
          placeholder="Price"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <input
          type="text"
          name="location"
          placeholder="Location"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <input
          type="text"
          name="country"
          placeholder="Country"
          style="
            padding: 0.5rem;
            width: 100%;
            border-bottom: 1px solid #ccc;
            border-radius: 1rem;
          "
        />
        <br />
        <div style="display: flex; justify-content: space-between; gap: 1rem">
        <button
          type="button"
          style="
            padding: 0.5rem;
            background-color: #6c757d;
            color: white;
            border: none;
            border-radius: 1rem;
            cursor: pointer;
          "
        >
          <a href="/listings" style="color: white; text-decoration: none;">Cancel</a>
        </button>
        <button
          type="submit"
          style="
            padding: 0.5rem;
            background-color: #ff385c;
            color: white;
            border: none;
            border-radius: 1rem;
            cursor: pointer;
          "
        >
          Add Listing
        </button>
        </div>
      </form>
    </div>
  </body>
</html>
