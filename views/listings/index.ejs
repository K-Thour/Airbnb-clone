<% layout("./layouts/boilerplate") %>
<body>
    <div style="display: flex; justify-content: space-around; align-items: center;">
        <h3>All Listings</h3>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% listings.forEach(listing => { %>
        <a href="/listings/<%= listing._id %>" class="col text-decoration-none text-dark">
    <div class="card">
  <img src="<%= listing.image.url %>" class="card-img-top" style="height: 20rem;" alt="<%= listing.image.filename %>">
  <div class="card-img-overlay">
  </div>
  <div class="card text-bg-dark">
</div>
  <div class="card-body">
    <p class="card-text"><b><%= listing.title %></b>  <br>&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
  </div>
</div>
</a>
<% }) %>
    </div>
</body>
</html>